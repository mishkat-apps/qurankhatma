rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isNonAnonymous() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isOwner(ownerUid) {
      return isSignedIn() && request.auth.uid == ownerUid;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /khatmas/{khatmaId} {
      allow read: if true;
      allow create: if isNonAnonymous() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(resource.data.ownerUid);

      match /juz/{juzId} {
        allow read: if true;
        allow create: if false;
        allow update: if isOwner(get(/databases/$(database)/documents/khatmas/$(khatmaId)).data.ownerUid)
          || (
            isSignedIn()
            && request.resource.data.participantUid == request.auth.uid
            && (
              resource.data.state == 'available'
              || resource.data.participantUid == request.auth.uid
            )
          );
      }
    }
  }
}
